# HTTP entrypoint + Certbot challenge handling.
server {
    listen 80;
    listen [::]:80;
    server_name portfolioforge.mlbautomation.com;

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name portfolioforge.mlbautomation.com;

    root /srv/portfolioforge/frontend/current;
    index index.html;

    ssl_certificate /etc/letsencrypt/live/portfolioforge.mlbautomation.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/portfolioforge.mlbautomation.com/privkey.pem;

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location ^~ /api/v1/ {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /health {
        proxy_pass http://127.0.0.1:8080/health;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location ^~ /assets/ {
        try_files $uri =404;
        access_log off;
        expires 1h;
    }

    location ~* \.(?:css|js|map|png|jpg|jpeg|gif|svg|ico|webp|woff2?)$ {
        try_files $uri =404;
        access_log off;
        expires 1h;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
