# Http seervice config
IS_HTTPS=false
SERVER_PORT=8080
CERT_PEM_FILE=./cretificate/cert.pem
KEY_PEM=./cretificate/key.pem
ALLOWED_ORIGINS=*,http://localhost:3000 # más usado por frontend
ALLOWED_METHODS=POST,GET,PUT,DELETE
JWT_SECRET_KEY=your-jwt-secret-key

# Files storage
IMAGES_DIR=./images

# Database
ENGINE=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=postgres
DB_SSL_MODE=disable

# PayPal config
WEBHOOK_ID=your-webhook-id
VALIDATION_URL=https://api.sandbox.paypal.com/v1/notifications/verify-webhook-signature
CLIENT_ID=your-client-id
SECRET_ID=your-secret-id

# Email verification (optional but required for real OTP delivery)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=mailer-user
SMTP_PASSWORD=mailer-password
EMAIL_FROM_ADDRESS=no-reply@example.com
EMAIL_FROM_NAME=PortfolioForge
